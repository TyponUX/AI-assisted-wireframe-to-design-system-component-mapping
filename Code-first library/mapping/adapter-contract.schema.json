{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "adapter-contract.schema.json",
  "title": "Client Adapter Contract",
  "type": "object",
  "required": ["client_id", "design_system", "version", "rules"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "client_id": {
      "type": "string",
      "minLength": 1
    },
    "design_system": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source_semantic_id", "target", "slot_map", "state_map", "fallback"],
        "properties": {
          "source_semantic_id": {
            "type": "string",
            "pattern": "^[a-z]+(\\.[a-z0-9_]+)+$"
          },
          "target": {
            "type": "object",
            "required": ["component", "import"],
            "properties": {
              "component": { "type": "string", "minLength": 1 },
              "import": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "slot_map": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": ["to"],
              "properties": {
                "to": { "type": "string", "minLength": 1 },
                "transform": {
                  "type": "string",
                  "enum": [
                    "direct",
                    "text_to_children",
                    "node_passthrough",
                    "list_passthrough",
                    "meta_passthrough",
                    "enum_map",
                    "boolean_invert",
                    "compose_props"
                  ]
                }
              },
              "additionalProperties": false
            }
          },
          "state_map": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "type": "object",
              "required": ["target_state"],
              "properties": {
                "target_state": { "type": "string", "minLength": 1 },
                "props": {
                  "type": "object",
                  "additionalProperties": true
                },
                "conditions": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              },
              "additionalProperties": false
            }
          },
          "fallback": {
            "type": "object",
            "required": ["component", "reason"],
            "properties": {
              "component": { "type": "string", "minLength": 1 },
              "reason": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "fallback_chain": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
